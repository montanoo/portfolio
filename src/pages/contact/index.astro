---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Fernando Montano | Contact">
    <main>
        <section class="min-h-screen">
            <div class="flex relative min-h-screen max-w-325 justify-center flex-col items-center px-8 mx-auto text-[#5b575a] dark:text-[#d6d3d1] py-16">

                <div class="w-full max-w-150 flex flex-col gap-6">
                    <div class="text-center md:text-left">
                        <p class="font-bold" data-i18n="contact.eyebrow">Let's talk. 💬</p>
                        <h1 class="font-[Manrope] text-2xl mt-2" data-i18n="contact.heading">Get in Touch</h1>
                        <p class="max-w-100 mt-2" data-i18n-html="contact.desc">Have a project in mind or just want to say hello? <span class="font-bold">I'd love to hear from you.</span></p>
                    </div>

                    <form id="contact-form" class="flex flex-col gap-4 mt-4">
                        <div class="flex flex-col md:flex-row gap-4">
                            <div class="flex flex-col gap-1.5 flex-1">
                                <label for="name" class="font-bold text-sm" data-i18n="contact.name">Name</label>
                                <input
                                    type="text" id="name" name="name" required
                                    placeholder="Your name"
                                    data-i18n-ph="contact.name.ph"
                                    class="border border-[#A1B5D8] dark:border-[#A1B5D8]/50 rounded-xl px-4 py-3 bg-white/50 dark:bg-white/5 outline-none focus:border-[#5b575a] dark:focus:border-[#d6d3d1] focus:ring-1 focus:ring-[#A1B5D8] transition-all placeholder:text-[#5b575a]/40 dark:placeholder:text-[#d6d3d1]/30 dark:text-[#d6d3d1]"
                                />
                            </div>
                            <div class="flex flex-col gap-1.5 flex-1">
                                <label for="email" class="font-bold text-sm" data-i18n="contact.email">Email</label>
                                <input
                                    type="email" id="email" name="email" required
                                    placeholder="you@example.com"
                                    data-i18n-ph="contact.email.ph"
                                    class="border border-[#A1B5D8] dark:border-[#A1B5D8]/50 rounded-xl px-4 py-3 bg-white/50 dark:bg-white/5 outline-none focus:border-[#5b575a] dark:focus:border-[#d6d3d1] focus:ring-1 focus:ring-[#A1B5D8] transition-all placeholder:text-[#5b575a]/40 dark:placeholder:text-[#d6d3d1]/30 dark:text-[#d6d3d1]"
                                />
                            </div>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="subject" class="font-bold text-sm" data-i18n="contact.subject">Subject</label>
                            <input
                                type="text" id="subject" name="subject" required
                                placeholder="What's this about?"
                                data-i18n-ph="contact.subject.ph"
                                class="border border-[#A1B5D8] dark:border-[#A1B5D8]/50 rounded-xl px-4 py-3 bg-white/50 dark:bg-white/5 outline-none focus:border-[#5b575a] dark:focus:border-[#d6d3d1] focus:ring-1 focus:ring-[#A1B5D8] transition-all placeholder:text-[#5b575a]/40 dark:placeholder:text-[#d6d3d1]/30 dark:text-[#d6d3d1]"
                            />
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="message" class="font-bold text-sm" data-i18n="contact.message">Message</label>
                            <textarea
                                id="message" name="message" required rows="6"
                                placeholder="Tell me about your project..."
                                data-i18n-ph="contact.message.ph"
                                class="border border-[#A1B5D8] dark:border-[#A1B5D8]/50 rounded-xl px-4 py-3 bg-white/50 dark:bg-white/5 outline-none focus:border-[#5b575a] dark:focus:border-[#d6d3d1] focus:ring-1 focus:ring-[#A1B5D8] transition-all resize-none placeholder:text-[#5b575a]/40 dark:placeholder:text-[#d6d3d1]/30 dark:text-[#d6d3d1]"
                            ></textarea>
                        </div>

                        <button
                            type="submit"
                            data-i18n="contact.submit"
                            class="border border-[#A1B5D8] dark:border-[#A1B5D8]/60 p-3 rounded-xl bg-[#a1b5d880] dark:bg-[#a1b5d825] font-bold cursor-pointer hover:bg-[#A1B5D8] dark:hover:bg-[#A1B5D8]/40 transition-all mt-2 active:scale-[0.98]"
                        >
                            Send Message ✉️
                        </button>

                        <div id="form-status" class="text-center text-sm hidden"></div>
                    </form>

                    <div class="flex justify-center mt-4">
                        <p class="text-[8px]" data-i18n="contact.footer">(i'll get back to you as soon as possible)</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    const MSGS: Record<string, Record<string, string>> = {
        en: {
            sending: 'Sending... ⏳',
            success: 'Message sent successfully! 🎉',
            error:   'Something went wrong. Please try again.',
            submit:  'Send Message ✉️',
        },
        es: {
            sending: 'Enviando... ⏳',
            success: '¡Mensaje enviado con éxito! 🎉',
            error:   'Algo salió mal. Por favor intenta de nuevo.',
            submit:  'Enviar mensaje ✉️',
        },
    };

    function getLang(): string {
        return localStorage.getItem('lang') || 'en';
    }

    function m(key: string): string {
        const lang = getLang();
        return (MSGS[lang] ?? MSGS.en)[key] ?? MSGS.en[key];
    }

    const form   = document.getElementById('contact-form') as HTMLFormElement;
    const status = document.getElementById('form-status') as HTMLDivElement;

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        button.textContent = m('sending');
        button.disabled = true;

        const data = Object.fromEntries(new FormData(form));

        try {
            const response = await fetch('https://j92cupwp88.execute-api.us-east-2.amazonaws.com/send-email', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
            });

            const result = await response.json();

            if (response.ok) {
                status.textContent = m('success');
                status.className = 'text-center text-sm text-green-600 font-bold';
                status.classList.remove('hidden');
                form.reset();
            } else {
                throw new Error(result.error || 'Failed to send');
            }
        } catch {
            status.textContent = m('error');
            status.className = 'text-center text-sm text-red-500 font-bold';
            status.classList.remove('hidden');
        } finally {
            button.textContent = m('submit');
            button.disabled = false;
        }
    });
</script>
