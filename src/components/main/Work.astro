---
import WorkCard from "../common/WorkCard.astro";
import Vamo from "../../assets/work/vamo.png"
import Fodors from "../../assets/work/fodors.png"
---

<WorkCard image={Fodors} title="Fodors" link="https://www.fodors.com" tags={['Fullstack', 'Vue', 'Laravel', 'PostgreSQL']} />
<WorkCard image={Vamo} title="Vamo Delivery" link="https://www.vamodelivery.com" tags={['Fullstack', 'React Native', 'Node.js', 'AWS', 'MySQL']} />

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>(".work-card").forEach((card, i) => {
    gsap.from(card, {
      opacity: 0,
      y: 50,
      duration: 0.8,
      ease: "power3.out",
      delay: i * 0.12,
      scrollTrigger: {
        trigger: card,
        start: "top 88%",
      },
    });
  });
</script>
