---
const categories = [
    {
        name: 'Frontend',
        items: [
            { label: 'React',        role: 'UI library'    },
            { label: 'Next.js',      role: 'Framework'     },
            { label: 'TypeScript',   role: 'Language'      },
            { label: 'JavaScript',   role: 'Language'      },
            { label: 'Vue',          role: 'Framework'     },
            { label: 'Tailwind',     role: 'Styling'       },
            { label: 'HTML5 & CSS3', role: 'Fundamentals'  },
        ],
    },
    {
        name: 'Backend',
        items: [
            { label: 'Node.js',    role: 'Runtime'   },
            { label: 'NestJS',     role: 'Framework' },
            { label: 'Express',    role: 'Framework' },
            { label: 'Laravel',    role: 'Framework' },
            { label: 'PostgreSQL', role: 'Database'  },
            { label: 'MySQL',      role: 'Database'  },
            { label: 'Redis',      role: 'Cache'     },
        ],
    },
    {
        name: 'Infra & DevOps',
        items: [
            { label: 'Docker',         role: 'Containers' },
            { label: 'Linux',          role: 'Systems'    },
            { label: 'GitHub Actions', role: 'CI/CD'      },
            { label: 'Jenkins',        role: 'CI/CD'      },
            { label: 'Vercel',         role: 'Hosting'    },
            { label: 'AWS',            role: 'Cloud'      },
        ],
    },
];
---

<section id="skills" class="relative md:h-[360vh] bg-ink text-paper">
    <div class="skillsPin md:sticky md:top-0 md:h-screen flex flex-col overflow-hidden px-6 md:px-14 pt-24 md:pt-[104px] pb-14">
        <!-- Header row -->
        <div class="flex items-end justify-between flex-wrap gap-5">
            <div>
                <div class="text-[15px] font-semibold text-accent-dk mb-4">02 — Skills</div>
                <h2 class="font-display font-semibold text-[clamp(28px,3.2vw,46px)] leading-[1.05] tracking-[-0.02em] m-0">
                    The tools I reach for.
                </h2>
            </div>
            <div class="flex gap-[7px] items-center">
                {categories.map((_, i) => (
                    <span
                        class="prog-dot w-[34px] h-1 rounded-full"
                        data-i={i}
                        style={`background:${i === 0 ? '#6f7cff' : '#3b3a31'}`}
                    ></span>
                ))}
            </div>
        </div>

        <!-- Body -->
        <div class="flex-1 grid md:grid-cols-[0.85fr_1.15fr] gap-10 md:gap-16 items-center mt-12 md:mt-0">
            <!-- Category switcher (desktop scrolly only) -->
            <div class="skills-switcher flex flex-col gap-4 md:gap-[22px]">
                {categories.map((cat, i) => (
                    <div
                        class="cat-item flex items-baseline gap-[18px]"
                        data-cat={i}
                        style={`opacity:${i === 0 ? '1' : '0.32'}`}
                    >
                        <span
                            class="cat-num font-display font-semibold text-[16px]"
                            style={`color:${i === 0 ? '#6f7cff' : '#5b5a50'}`}
                        >0{i + 1}</span>
                        <span
                            class="cat-name font-display font-semibold text-[clamp(34px,4.4vw,60px)] tracking-[-0.02em] leading-none"
                            style={`color:${i === 0 ? '#f3f0e9' : '#5b5a50'}`}
                        >{cat.name}</span>
                    </div>
                ))}
            </div>

            <!-- Stacked panels -->
            <div class="relative min-h-[360px] md:min-h-[420px]">
                {categories.map((cat, i) => (
                    <div
                        class="cat-panel absolute inset-0"
                        data-cat={i}
                        data-name={cat.name}
                        style={`opacity:0; transform:translateY(${i === 0 ? '0' : '24px'})`}
                    >
                        {cat.items.map((item) => (
                            <div class="sk-item flex items-center justify-between py-[13px] border-b border-[#2a2921]" style="opacity:0.15; transform:translateX(20px)">
                                <span class="font-display font-medium text-[clamp(20px,2.2vw,30px)] tracking-[-0.01em]">{item.label}</span>
                                <span class="text-[13px] text-ink-faint">{item.role}</span>
                            </div>
                        ))}
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
