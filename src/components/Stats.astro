---
const stats = [
    { value: '5',  label: 'Years of experience'    },
    { value: '20', label: 'Projects shipped'       },
    { value: '10', label: 'Clients & teams served' },
];
---

<section class="px-6 md:px-14 py-20 md:py-24 bg-paper-alt border-t border-b border-line-soft">
    <div class="grid grid-cols-3 gap-6 md:gap-10 text-center">
        {stats.map((s, i) => (
            <div class={`fx ${i === 1 ? 'border-l border-r border-[#d7d2c5]' : ''}`}>
                <div class="font-display font-bold text-[clamp(40px,8vw,92px)] leading-none tracking-[-0.03em]">
                    {s.value}<span class="text-accent">+</span>
                </div>
                <div class="text-[13px] md:text-[15px] font-medium text-ink-muted mt-3">{s.label}</div>
            </div>
        ))}
    </div>
</section>
