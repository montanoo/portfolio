---
import {Image} from "astro:assets";
import Me from "../assets/me.png";
import Social from "./main/Social.astro";
import BounceArrow from "./main/BounceArrow.astro";
import Skills from "./main/Skills.astro";
import Work from "./main/Work.astro";
---

<main>
    <section class="min-h-screen">
        <div class="flex relative h-screen max-w-325 justify-center flex-col md:flex-row items-center px-8 mx-auto text-[#5b575a] dark:text-[#d6d3d1]">
            <div class="order-2 md:order-1 flex flex-col gap-4 text-center md:text-left">
                <p class="font-bold hero-greeting" data-i18n="hero.greeting">Hello. 👋</p>
                <p class="font-[Manrope] text-2xl hero-name" data-i18n="hero.name">I'm Fernando Montano</p>
                <p class="max-w-100 md:max-w-full hero-desc" data-i18n-html="hero.description">A passionate engineer, able to create <span class="font-bold">high scalable code and exceptional UX.</span></p>
                <p class="text-[8px] hero-pixel" data-i18n="hero.pixel">(and pixel perfect designs)</p>
                <div class="flex justify-center md:justify-start hero-badge">
                    <div class="border border-[#A1B5D8] p-2 rounded-xl bg-[#a1b5d880] dark:bg-[#a1b5d830]">
                        <span class="font-bold" data-i18n="hero.badge">Fullstack Developer @</span> Willdom
                    </div>
                </div>
                <div class="hero-social">
                    <Social />
                </div>
            </div>
            <div class="order-1 mb-8 md:pt-0 md:order-2 hero-image">
                <Image src={Me} alt="Me" width={700} height={700} class="rounded-4xl" loading="eager"/>
            </div>
            <BounceArrow />
        </div>
    </section>

    <section class="min-h-screen" id="skills">
        <div class="px-8 md:h-screen max-w-325 mx-auto flex flex-col md:flex-row py-8 text-[#5b575a] dark:text-[#d6d3d1]">
            <div class="md:w-1/2">
                <h2 class="font-bold text-2xl pb-2 section-heading" data-i18n="skills.title">Skills:</h2>
                <p class="max-w-50 pb-2 section-desc" data-i18n="skills.desc">I have used the following tools profesionally.</p>
            </div>
            <Skills />
        </div>
    </section>

    <section id="work">
        <div class="px-8 max-w-325 mx-auto py-8">
            <div class="text-[#5b575a] dark:text-[#d6d3d1]">
                <h2 class="font-bold text-2xl pb-2 section-heading" data-i18n="work.title">Work:</h2>
                <p class="max-w-50 pb-2 section-desc" data-i18n="work.desc">I have worked on the following projects.</p>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                <Work />
            </div>
        </div>
    </section>
</main>

<style>
main {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Hero entrance — sequential timeline
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
  tl.from('.hero-greeting', { opacity: 0, y: 24, duration: 0.6 })
    .from('.hero-name',     { opacity: 0, y: 24, duration: 0.6 }, '-=0.4')
    .from('.hero-desc',     { opacity: 0, y: 24, duration: 0.6 }, '-=0.4')
    .from('.hero-pixel',    { opacity: 0, y: 14, duration: 0.4 }, '-=0.3')
    .from('.hero-badge',    { opacity: 0, y: 14, duration: 0.4 }, '-=0.3')
    .from('.hero-social',   { opacity: 0, y: 14, duration: 0.4 }, '-=0.3')
    .from('.hero-image',    { opacity: 0, x: 40, scale: 0.96, duration: 1.0, ease: 'power2.out' }, 0.15);

  // Section headings & descriptions — scroll-triggered
  gsap.utils.toArray<HTMLElement>('.section-heading').forEach((el) => {
    gsap.from(el, {
      opacity: 0, y: 20, duration: 0.6, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 88%' },
    });
  });

  gsap.utils.toArray<HTMLElement>('.section-desc').forEach((el) => {
    gsap.from(el, {
      opacity: 0, y: 14, duration: 0.5, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 90%' },
    });
  });
</script>
