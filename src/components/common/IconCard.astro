---
const { icon, title } = Astro.props;
import { Icon } from 'astro-icon/components';
---

<div class="bg-[#EFF1F3] dark:bg-[#292524] p-4 flex flex-col items-center justify-center rounded-lg h-24 skill-card">
    <Icon name={icon} class="w-8 h-8 text-[#5b575a] dark:text-[#d6d3d1]" />
    <h3 class="text-xs font-bold text-[#5b575a] dark:text-[#d6d3d1]">{title}</h3>
</div>
