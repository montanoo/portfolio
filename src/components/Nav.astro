---
const links = [
    { href: '#about',    label: 'About'    },
    { href: '#skills',   label: 'Skills'   },
    { href: '#services', label: 'Services' },
    { href: '#work',     label: 'Work'     },
];
---

<nav class="sticky top-0 z-50 flex items-center justify-between px-6 md:px-14 py-[18px] md:py-[22px] bg-paper/80 backdrop-blur-[10px] border-b border-line">
    <a href="#top" class="font-display font-extrabold text-[26px] tracking-[-0.02em] leading-none">
        FM<span class="text-accent">.</span>
    </a>

    <div class="hidden md:flex gap-[38px] text-[15px] font-medium text-[#3d3c34]">
        {links.map(({ href, label }) => (
            <a class="navlink" href={href}>{label}</a>
        ))}
    </div>

    <a
        href="#contact"
        class="text-[14px] font-medium border border-ink rounded-full px-5 py-2.5 hover:bg-ink hover:text-paper transition-colors duration-300"
    >
        Let's talk ↗
    </a>
</nav>
