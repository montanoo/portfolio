---
const services = [
    {
        title: 'Frontend Development',
        desc:  'Responsive, accessible interfaces in React & Next.js — fast, consistent, and pixel-perfect down to the last detail.',
    },
    {
        title: 'Fullstack Engineering',
        desc:  'End-to-end product work — APIs, databases, and business logic with Node, NestJS, Laravel and SQL, built to scale.',
    },
    {
        title: 'UX & Interface Design',
        desc:  'Thoughtful layouts, clear hierarchy and smooth interactions — turning rough ideas into interfaces people enjoy using.',
    },
    {
        title: 'Cloud & DevOps',
        desc:  'Containerized deploys, CI/CD pipelines and reliable infrastructure with Docker, GitHub Actions and cloud platforms.',
    },
];
---

<section id="services" class="px-6 md:px-14 py-24 md:py-[120px]">
    <div class="fx text-[15px] font-semibold text-accent mb-[18px]">03 — Services</div>
    <h2 class="fx font-display font-semibold text-[clamp(34px,4vw,56px)] leading-[1.05] tracking-[-0.02em] m-0 mb-16 max-w-[760px]">
        What I can build for you.
    </h2>

    <div class="border-t border-line-soft">
        {services.map((s, i) => (
            <div class="fx grid grid-cols-[40px_1fr] md:grid-cols-[60px_1fr_1.4fr] gap-x-6 md:gap-x-8 gap-y-3 py-[34px] border-b border-line-soft items-start">
                <div class="font-display font-semibold text-[20px] text-[#b4b1a4]">0{i + 1}</div>
                <div class="font-display font-semibold text-[22px] md:text-[26px] tracking-[-0.01em]">{s.title}</div>
                <div class="col-span-2 md:col-span-1 md:col-start-3 text-[16px] md:text-[17px] leading-[1.6] text-ink-muted">{s.desc}</div>
            </div>
        ))}
    </div>
</section>
