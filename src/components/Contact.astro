---
const year = new Date().getFullYear();
---

<section id="contact" class="px-6 md:px-14 py-28 md:py-[130px] bg-ink text-paper">
    <div class="max-w-[980px]">
        <div class="fx text-[15px] font-semibold text-accent-dk mb-6">05 — Contact</div>
        <h2 class="fx font-display font-semibold text-[clamp(44px,7vw,104px)] leading-[0.98] tracking-[-0.03em] m-0">
            Let's build<br />something<span class="text-accent-dk">.</span>
        </h2>
        <p class="fx text-[19px] leading-[1.6] text-[#a19f93] max-w-[520px] mt-9 mb-11">
            Have a project in mind, or just want to say hi? I'm always open to interesting work and good conversations.
        </p>
        <div class="fx flex gap-3.5 flex-wrap">
            <a href="mailto:hello@montano.me" class="bg-paper text-ink text-[16px] font-semibold px-[30px] py-4 rounded-full hover:opacity-90 transition-opacity duration-300">
                hello@montano.me
            </a>
            <a href="https://www.linkedin.com/in/fernandojmontano/" target="_blank" rel="noopener" class="border border-[#4a4940] text-[16px] font-medium px-[30px] py-4 rounded-full hover:border-paper transition-colors duration-300">
                LinkedIn ↗
            </a>
            <a href="https://github.com/montanoo" target="_blank" rel="noopener" class="border border-[#4a4940] text-[16px] font-medium px-[30px] py-4 rounded-full hover:border-paper transition-colors duration-300">
                GitHub ↗
            </a>
        </div>
    </div>

    <div class="flex items-center justify-between mt-24 md:mt-28 pt-8 border-t border-[#33322a] flex-wrap gap-4">
        <div class="font-display font-extrabold text-[22px]">FM<span class="text-accent-dk">.</span></div>
        <div class="text-[14px] text-ink-faint">© {year} Fernando Montano — Fullstack Developer</div>
    </div>
</section>
